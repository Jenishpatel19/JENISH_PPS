#include <stdio.h>

int main() {
    int num, original, reverse = 0, remainder;

    printf("Enter a five digit number: ");
    scanf("%d", &num);

    original = num;

    while(num != 0) {
        remainder = num % 10;
        reverse = reverse * 10 + remainder;
        num = num / 10;
    }

    if(original == reverse)
        printf("Number is Palindrome");
    else
        printf("Number is Not Palindrome");

    return 0;
}