#include <stdio.h>

int main() {
    int i, j;
    char ch;

    for(i = 5; i >= 1; i--) {
        
        // Decide character (uppercase for odd position, lowercase for even)
        if(i % 2 == 1)
            ch = 'A' + i - 1;      // Uppercase
        else
            ch = 'a' + i - 1;      // Lowercase
        
        // Print character i times
        for(j = 1; j <= i; j++) {
            printf("%c", ch);
        }
        
        printf("\n");
    }

    return 0;
}