#include <stdio.h>
#include <string.h>

// Function for sorting array (Bubble Sort)
void sortArray(int arr[], int n) {
    int i, j, temp;
    for(i = 0; i < n - 1; i++) {
        for(j = 0; j < n - i - 1; j++) {
            if(arr[j] > arr[j + 1]) {
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
    printf("Sorted Array: ");
    for(i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
}

// Function for searching element (Linear Search)
void searchArray(int arr[], int n, int key) {
    int i, found = 0;
    for(i = 0; i < n; i++) {
        if(arr[i] == key) {
            printf("Element found at position %d", i + 1);
            found = 1;
            break;
        }
    }
    if(!found) {
        printf("Element not found");
    }
}

// Function for string concatenation
void concatString(char s1[], char s2[]) {
    strcat(s1, s2);
    printf("Concatenated String: %s", s1);
}

// Function for string comparison
void compareString(char s1[], char s2[]) {
    if(strcmp(s1, s2) == 0)
        printf("Strings are equal");
    else
        printf("Strings are not equal");
}

int main() {
    int choice, type;

    printf("Select Type:\n1. Array Operations\n2. String Operations\n");
    scanf("%d", &type);

    if(type == 1) {
        int n, arr[100], i, key;

        printf("Enter size of array: ");
        if(scanf("%d", &n) != 1 || n <= 0) {
            printf("Invalid size");
            return 0;
        }

        printf("Enter elements:\n");
        for(i = 0; i < n; i++) {
            scanf("%d", &arr[i]);
        }

        printf("\n1. Sort\n2. Search\n");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                sortArray(arr, n);
                break;
            case 2:
                printf("Enter element to search: ");
                scanf("%d", &key);
                searchArray(arr, n, key);
                break;
            default:
                printf("Invalid choice");
        }
    }

    else if(type == 2) {
        char s1[100], s2[100];

        printf("Enter first string: ");
        scanf("%s", s1);
        printf("Enter second string: ");
        scanf("%s", s2);

        printf("\n1. Concatenate\n2. Compare\n");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                concatString(s1, s2);
                break;
            case 2:
                compareString(s1, s2);
                break;
            default:
                printf("Invalid choice");
        }
    }

    else {
        printf("Invalid type selection");
    }

    return 0;
}